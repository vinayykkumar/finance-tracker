# API base (no trailing slash). Backend must run with cookie sessions:
#   uvicorn app.main_auth:app --reload
#
# Android emulator → host:
#   EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
# iOS simulator:
#   EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# Physical device → your PC LAN IP (and add that origin to fin-backend CORS_ORIGINS):
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:8000
#
# Use the SAME hostname you use in the browser for the API (localhost vs 127.0.0.1)
# so SameSite=Lax session cookies are sent on fetch from the app.
#
# Optional timeout (ms), default 25000:
# EXPO_PUBLIC_API_TIMEOUT_MS=25000

EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
