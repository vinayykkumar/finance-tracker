# Base URL of the API (modular monolith), no trailing slash.
# Local dev (Vite): http://127.0.0.1:8000 — see repo `scripts/dev-backend.ps1`.
# Docker (`docker compose up`): leave empty so the UI uses same-origin `/v1/...` (nginx proxies to the API).
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: default timeout for API requests (ms). Default: 25000
# VITE_API_TIMEOUT_MS=25000
