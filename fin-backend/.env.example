# Copy to .env. Postgres is not part of this repo — run it however you like (Docker below is optional).

# Example: standalone local Postgres (Docker only; not tied to this project):
#   docker run -d --name finance-postgres-local -e POSTGRES_USER=finance -e POSTGRES_PASSWORD=finance -e POSTGRES_DB=finance -p 5432:5432 -v finance_pg_local:/var/lib/postgresql/data postgres:16-alpine
#
# Apply schema changes before starting the API (repeat after pulling migrations):
#   cd fin-backend && poetry run alembic upgrade head
#   Or from repo root: pwsh ./scripts/migrate.ps1

DATABASE_URL=postgresql+asyncpg://finance:finance@127.0.0.1:5432/finance

# development | staging | production
# In staging/production, SECRET_KEY must be >= 32 characters and cannot be the literal "change-me".
ENVIRONMENT=development

# Session cookie signing for `uvicorn app.main:app` (full API with auth).
# In staging/production, cookies use Secure + a strong SECRET_KEY is enforced.
SECRET_KEY=change-me-to-a-long-random-secret

# Comma-separated browser origins (Vite default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# API bind (optional; dev scripts use 127.0.0.1:8000)
HOST=127.0.0.1
PORT=8000
