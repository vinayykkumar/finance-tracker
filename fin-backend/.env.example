# Copy to .env. Postgres is not part of this repo — run it however you like (Docker below is optional).

# Example: standalone local Postgres (Docker only; not tied to this project):
#   docker run -d --name finance-postgres-local -e POSTGRES_USER=finance -e POSTGRES_PASSWORD=finance -e POSTGRES_DB=finance -p 5432:5432 -v finance_pg_local:/var/lib/postgresql/data postgres:16-alpine
#
# On first run the API runs `alembic upgrade head` (sync URL derived from DATABASE_URL).
# If you previously used auto `create_all` only, drop the DB or reset the schema before upgrading,
# or stamp: `poetry run alembic stamp 0001_initial` if tables already match that migration.

DATABASE_URL=postgresql+asyncpg://finance:finance@127.0.0.1:5432/finance

# Session cookie signing — only used when you run the auth-enabled app (`app.main_auth:app`).
# Default dev API (`app.main:app`) does not mount `/v1/auth` or session middleware.
# Financial goals (`/v1/goals`) are mounted only with `app.main_auth:app` (session required).
# Same for `/v1/accounts`, `/v1/transactions`, `/v1/budgets`.
SECRET_KEY=change-me-to-a-long-random-secret

# Comma-separated browser origins (Vite default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# API bind (optional; dev scripts use 127.0.0.1:8000)
HOST=127.0.0.1
PORT=8000
